# ============================================================
# SUPABASE
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# ============================================================
# PIPELINE LLM PROVIDER
# Options: anthropic | openrouter | ollama | lm_studio
# ============================================================
LLM_PROVIDER=anthropic
PIPELINE_SMART_MODEL=claude-sonnet-4-6
PIPELINE_FAST_MODEL=claude-haiku-4-5-20251001

# ============================================================
# ANTHROPIC (default)
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================
# GPT RESEARCHER CONFIGURATION
# ============================================================
TAVILY_API_KEY=your_tavily_api_key_here
RETRIEVER=tavily
SMART_LLM=claude-sonnet-4-6
FAST_LLM=claude-haiku-4-5-20251001
STRATEGIC_LLM=claude-sonnet-4-6
MAX_SCRAPER_WORKERS=15
MAX_SEARCH_RESULTS_PER_QUERY=5
CURATE_SOURCES=false
